# App / frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Postgres database
DATABASE_URL=

# Deployment
VERCEL_FRONTEND_URL=https://your-frontend-domain.vercel.app
RENDER_EXTERNAL_URL=https://your-render-service.onrender.com

# Request limits
MAX_UPLOAD_KB=50
REQUEST_TIMEOUT_SECONDS=40

# LLM provider
LLM_ENABLED=true
LLM_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
LLM_FAST_MODEL=gemini-3.0-flash-preview
LLM_FAST_FALLBACK_MODEL=gemini-2.5-flash
LLM_STRONG_MODEL=qwen-3-235b-a22b-instruct-2507
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=3

