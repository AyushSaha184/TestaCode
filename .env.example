# App / frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Postgres database
DATABASE_URL=

# Deployment
VERCEL_FRONTEND_URL=https://your-frontend-domain.vercel.app
RENDER_EXTERNAL_URL=https://your-render-service.onrender.com

# Redis cache
USE_REDIS_CACHE=true
REDIS_URL=redis://default:password@host:port/0
REDIS_KEY_PREFIX=testacode

# Request limits
MAX_UPLOAD_KB=50
REQUEST_TIMEOUT_SECONDS=40

# LLM provider
LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
LLM_FAST_MODEL=gemini-2.0-flash
LLM_STRONG_MODEL=minimax/minimax-m2.5:free
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=3

