# Frontend/backend local origin
ALLOWED_ORIGINS=your vercel url, localhost url

# Postgres database
SUPABASE_DB_URL= connecting string (Direct for local, transaction pooler for render)

# Supabase storage
# Set SUPABASE_URL to enable bucket uploads.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Redis cache
USE_REDIS_CACHE=true
REDIS_URL=rediss://default:password@host:port/0
REDIS_KEY_PREFIX=

# Request limits
MAX_UPLOAD_KB=50
REQUEST_TIMEOUT_SECONDS=40

# LLM provider
LLM_ENABLED=false
LLM_BASE_URL=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
LLM_FAST_MODEL=google/gemini-3.0-flash
LLM_STRONG_MODEL=minimax/minimax-m2.5:free
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=3
